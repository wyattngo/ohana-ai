# macOS
.DS_Store
._*

# Python (Phase 1.1+ sẽ dùng)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
# .python-version — INTENTIONALLY tracked (Phase 1.1 pin — pyenv/rye auto-select 3.11)

# IDE
.vscode/
.idea/

# Env / secrets
.env
.env.*
!.env.example
*.pem
*.key
secure/

# ADP generated artifacts (regeneratable từ spine)
# Hai file dưới bị GHI TRONG LÚC execute (audit log mỗi lần chấm gate; red-proof lúc
# `adp-review.sh red`, tức trước code). Tracked thì mỗi lần ghi là `git diff HEAD` đổi
# ⇒ verdict vừa stamp hết bind, checkpoint REFUSE oan (KI-020).
.adp-audit.jsonl
.adp-red-proof.json
.adp-state/

# Claude local overrides (không share)
.claude/settings.local.json

# Logs
*.log
logs/

# Test cache
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage

