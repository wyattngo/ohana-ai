# =============================================================================
# Ohana AI Seller — Environment template
# =============================================================================
# CÁCH DÙNG:
#   cp .env.example .env      → rồi điền giá trị thật vào .env
#
# ⚠️  .env KHÔNG BAO GIỜ được commit (đã gitignore). File .example NÀY thì có
#     — nên tuyệt đối KHÔNG điền giá trị thật vào đây, chỉ để placeholder.
#
# GHI CHÚ TRẠNG THÁI:
#   [LIVE]    = code đang đọc thật, verified on-disk 2026-07-18
#   [PLANNED] = chưa wire, liệt kê trước để admin biết sẽ cần (sẽ đọc ở spec tương ứng)
# =============================================================================


# -----------------------------------------------------------------------------
# 1. CORE  [LIVE]  — bắt buộc
# -----------------------------------------------------------------------------

# Môi trường chạy. CHỈ đúng chuỗi "dev" mới mở các đường dev-only:
#   - api/mock_auth.py  → route POST /api/mock/authorize (đăng nhập giả)
#   - api/admin.py      → _DeterministicDevEmbedder (vector giả, chỉ để test)
# Bất kỳ giá trị nào khác (kể cả rỗng/không set) = hành vi production, fail-closed.
# 🚫 TUYỆT ĐỐI không set "dev" trên production — nó mở route đăng nhập không mật khẩu.
OHANA_ENV=dev

# Postgres + pgvector. Default trong code: postgresql+psycopg://ohana:ohana@localhost:5432/ohana
# Cũng được đọc bởi Alembic (db/migrations/env.py) khi chạy migration.
DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:5432/<dbname>

# Secret ký/verify JWT phiên seller (HS256).
# ⚠️ FAIL-CLOSED: nếu KHÔNG set và OHANA_ENV != "dev" → app RAISE, không chạy.
#    Đây là chủ ý (chống deploy quên secret rồi attacker forge cookie shop_id bất kỳ
#    = cross-tenant bypass). Đừng "sửa" bằng cách nhét giá trị tạm vào production.
# 🚫 ĐỪNG copy nguyên giá trị mẫu từ file này — file .example được COMMIT, nên bất kỳ
#    giá trị nào ở đây đều là CÔNG KHAI. Tự sinh:  openssl rand -hex 32
OHANA_JWT_SECRET=


# -----------------------------------------------------------------------------
# 2. LLM PROVIDER — Together AI  [PLANNED]  ← ưu tiên 1 (General Chat)
# -----------------------------------------------------------------------------
# Provider đã chốt (ADR docs/adr/2026-07-18-hosting-region.md): Together open-weight,
# dùng cho CẢ LLM lẫn embedding. Sẽ được đọc khi spec General Chat land.

# API key Together. Lấy tại dashboard Together → Settings → API Keys.
# Điền vào .env của bạn, KHÔNG điền vào file .example này (file này được commit).
TOGETHER_API_KEY=

# Model LLM cho General Chat. Wyatt ký PRE-G02 lại 2026-07-19 (spec 07 §14).
#
# ⚠️ ĐỂ TRỐNG CŨNG ĐƯỢC — code sẽ dùng đúng giá trị dưới đây làm mặc định
#    (app/config.py DEFAULT_TOGETHER_MODEL). Biến rỗng được xử lý như KHÔNG khai báo.
#    Trước 2026-07-19 thì KHÔNG như vậy: `TOGETHER_MODEL=` rỗng ghi đè default thành "",
#    rồi rơi tiếp về model của OpenAI ⇒ Together trả 404. Đã vá cả hai tầng, nhưng vẫn
#    điền sẵn giá trị ở đây để người đọc biết mình đang chạy model nào.
#
# ⚠️ Danh sách /v1/models KHÔNG chứng minh model dùng được: `Qwen/Qwen2.5-72B-Instruct-Turbo`
#    có trong danh sách, có cả bảng giá, mà gọi vẫn 400 "non-serverless". Dò 148 model chat
#    ⇒ 6 cái thật sự phục vụ. Đổi model xong PHẢI chạy:
#       .venv/bin/python -m pytest tests/test_together_live.py -m live
#
# ⚠️ TRÁNH model reasoning (gpt-oss, GLM, Kimi, Qwen3.5-9B) cho endpoint này: chúng trả
#    content RỖNG khi max_tokens không đủ chỗ suy luận. api/chat.py bắt và trả 502, nhưng
#    tốt nhất là đừng chọn phải.
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Model embedding. 1024-dim, đa ngôn ngữ (93 thứ tiếng, có tiếng Việt).
# ⚠️ ĐỔI DIMENSION = BREAKING: db/models.py:22 đang khoá _EMBED_DIM = 1536.
#    Chuyển sang e5 (1024) BẮT BUỘC: Alembic migration cột embeddings.embedding
#    + re-embed toàn bộ corpus. Không set biến này rồi mong nó tự chạy.
# ⚠️ e5 cần prefix "query:" / "passage:" đúng chỗ — thiếu thì retrieval tụt âm thầm,
#    không báo lỗi. Xem ADR §Consequences.
TOGETHER_EMBED_MODEL=intfloat/multilingual-e5-large-instruct


# -----------------------------------------------------------------------------
# 3. OpenAI  [LIVE]  — đang bị Together thay thế
# -----------------------------------------------------------------------------
# Còn ở đây vì code hiện tại vẫn đọc (F1 embedder đã ship dùng OpenAI).
# Sau khi swap sang Together xong → cụm này thành dead config, xoá lúc đó.

# ⚠️ ĐỂ RỖNG trừ khi thật sự muốn dùng OpenAI.
#    `api/admin.py default_embedder()` chọn embedder bằng phép thử truthy trên biến này:
#    có giá trị (kể cả chuỗi placeholder vô nghĩa) → chọn OpenAIEmbedder THẬT → gọi API hỏng.
#    Rỗng → dev embedder (đúng cho dev). Đang chuyển sang Together nên bình thường cứ để rỗng.
OPENAI_API_KEY=

# ⚠️ 1536-dim, KHOÁ CỨNG với Vector(1536) ở db/models.py:22.
#    Đổi model khác dimension mà không migration = vector rác, retrieval sai âm thầm.
OPENAI_EMBED_MODEL=text-embedding-3-small

# Model chat (client tồn tại nhưng chưa wire vào đường chạy nào).
OPENAI_MODEL=gpt-4o-mini

# Danh sách model bật "reasoning mode". Mặc định frozenset() rỗng.
# 🚫 ĐỪNG set rỗng kiểu `REASONING_MODELS=` — đây là field kiểu phức (frozenset[str]),
#    pydantic-settings parse bằng JSON nên chuỗi rỗng làm Settings() RAISE
#    ⇒ TOÀN BỘ APP không khởi động được. Muốn "rỗng" thì BỎ HẲN dòng này (đúng cách),
#    hoặc dùng JSON array: REASONING_MODELS=["model-a","model-b"]
# (để nguyên dạng comment bên dưới — chỉ mở khi thật sự cần)
# REASONING_MODELS=["model-a"]


# -----------------------------------------------------------------------------
# 4. SẮP DÙNG  [PLANNED]  — chưa wire, để admin chuẩn bị trước
# -----------------------------------------------------------------------------

# ⚠️ CẢ CỤM NÀY ĐỂ RỖNG cho tới khi tính năng tương ứng được wire.
#    Lý do: code chọn nhánh bằng phép thử truthy — một chuỗi placeholder vô nghĩa
#    vẫn là "đã set", sẽ đẩy app vào nhánh "có cấu hình thật" rồi hỏng lúc gọi.

# --- Zalo OA (PRE-004, chờ Tân) — Spec 03c real send-leg ---
ZALO_OA_ACCESS_TOKEN=
ZALO_WEBHOOK_SECRET=

# --- Ohana platform REST API (PRE-002, chờ Tân) — Spec 03d F2 tools ---
# vd: https://api.example.internal
OHANA_API_BASE_URL=
OHANA_API_KEY=

# --- Redis (Spec 03b credit metering + per-shop rate-limit) ---
# ⚠️ Rate-limit/metering in-memory chỉ đúng khi 1 worker. Nhiều uvicorn worker
#    → đếm sai, chặn sai. Cần shared store trước khi metering là thật.
# vd: redis://localhost:6379/0
REDIS_URL=

# --- OpenTelemetry (Spec 03b observability + p95 gate) ---
# vd: http://otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ohana-ai


# =============================================================================
# GHI CHÚ BẢO MẬT (cho admin)
# =============================================================================
# 1. Bí mật thật sự trong file này: OHANA_JWT_SECRET, TOGETHER_API_KEY,
#    OPENAI_API_KEY, ZALO_*, OHANA_API_KEY. Rò một cái = phải xoay (rotate) ngay.
# 2. KHÔNG commit .env. KHÔNG paste key vào chat/ticket/screenshot.
# 3. OHANA_JWT_SECRET rò = attacker forge được session bất kỳ shop_id nào
#    (cross-tenant). Xoay secret = đá toàn bộ phiên đang đăng nhập — có chủ ý.
# 4. Data residency (ADR 2026-07-18): dữ liệu khách VN đi qua LLM provider nước
#    ngoài = chuyển dữ liệu xuyên biên → cần TIA + consent. Xem ADR trước khi
#    trỏ endpoint sang region khác.
# =============================================================================
